# 复制为 .env 使用。全部都有默认值,通常留空直接跑也行。

# 登录 cookie:一般不用填,用 App 内扫码登录即可(cookie 会存进数据卷)。
# 想跳过扫码、直接带登录态时,才填你自己的 MUSIC_U 值。
NCM_MUSIC_U=

# 对外端口。80 被占用(比如群晖 DSM 占了 80)时改成别的,如 8080。
APP_PORT=80

# 区域解锁:解掉“有版权但海外变灰”的歌(靠你自己账号版权)。
# 开启后后端每次请求自动随机生成一个中国大陆 IP,不用你指定。true=开,false=关(默认)。
REGION_UNLOCK=false

# 灰歌解锁:对“无版权的灰歌”从 QQ/酷狗/酷我/咪咕等找同名歌替换播放(即 NetEaseMusicWorld 那类做法)。
# true=开,false=关(默认)。注意:匹配可能串成错版本/翻唱/现场,音质不一,风险自负。
ENABLE_UNBLOCK=false

# Cloudflare 隧道 token。想要固定的公网 https 地址(群晖/VPS 常用)时填,
# 然后用  docker compose --profile tunnel up -d  启动。留空则不用隧道服务。
CLOUDFLARE_TUNNEL_TOKEN=
