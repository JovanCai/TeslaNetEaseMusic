# 复制为 .env 后填写。注意两类变量生效时机不同:

# —— 运行时(docker compose 注入给 nginx,前端/浏览器不可见)——
# 你的网易云登录 cookie(仅 MUSIC_U 值)
NCM_MUSIC_U=你的MUSIC_U值

# —— 构建时(npm run build 时被 Vite 嵌入静态产物;改后必须重新 build)——
# 可选:区域解锁用的国内 IP,留空=不解锁(默认)
VITE_REAL_IP=

# 部署流程:
#   set -a; . ./.env; set +a          # 载入变量
#   npm --prefix web run build         # 用 VITE_* 构建前端
#   docker compose up -d               # nginx 注入 NCM_MUSIC_U 并服务 dist
